# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bulkmailsend
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password

# Docker-specific DB config (used by docker-compose.yml)
